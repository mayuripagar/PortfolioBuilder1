<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Portfolio Builder</title>

    <!-- ✅ ADD CSS HERE (INSIDE HEAD) -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
   
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4"
               asp-controller="Home" asp-action="Index">
                Portfolio Builder
            </a>

            <div>
                <a class="nav-link text-white d-inline me-3"
                   asp-controller="Dashboard" asp-action="Index">
                    Dashboard
                </a>
                <a class="btn btn-outline-light"
                   asp-controller="Profiles" asp-action="Index">
                  Profile
                </a>
                @* <a class="btn btn-outline-light"
                   asp-controller="Home" asp-action="Preview">
                    Preview
                </a> *@
            </div>
        </div>
    </nav>

    @* <div>
        @RenderBody()
    </div> *@
    @RenderBody()

    <!-- Render optional per-view Scripts section -->
    @RenderSection("Scripts", required: false)
    <!-- Optional Bootstrap JS -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>



